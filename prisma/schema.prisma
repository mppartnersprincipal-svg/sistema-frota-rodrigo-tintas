// schema.prisma

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(cuid())
  name        String
  cpf         String   @unique // Identificador de login (apenas dígitos)
  pin         String   // Senha de 4 dígitos
  role        String   @default("DRIVER") // "ADMIN" ou "DRIVER"
  vehicleId   String?  // Veículo registrado no cadastro
  trips       Trip[]
  createdAt   DateTime @default(now())
}

model Vehicle {
  id         String   @id @default(cuid())
  plate      String   @unique
  model      String
  current_km Int      // Atualizado a cada rota finalizada
  isActive   Boolean  @default(true)
  trips      Trip[]
}

model Trip {
  id        String   @id @default(cuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id])
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])

  start_km   Int
  start_time DateTime @default(now()) // Gerado no servidor no momento do clique

  end_km   Int?
  end_time DateTime? // Atualizado no servidor no momento de finalizar

  orders String // Ex: "104010, 104063"

  totalSteps  Int @default(1) // Quantidade de pedidos (paradas)
  currentStep Int @default(0) // Parada atual; 0 = nenhuma iniciada ainda

  status    String   @default("IN_PROGRESS") // "IN_PROGRESS" ou "COMPLETED"
  createdAt DateTime @default(now())

  stops TripStop[]
}

model TripStop {
  id         String    @id @default(cuid())
  tripId     String
  trip       Trip      @relation(fields: [tripId], references: [id])
  stepNumber Int                               // 1-based
  start_time DateTime  @default(now())
  end_time   DateTime?
  status     String    @default("IN_PROGRESS") // "IN_PROGRESS" | "COMPLETED"
}
